FROM golang:1.25.8-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# バッチ（HTTPサーバ不要）
RUN CGO_ENABLED=0 GOOS=linux go build -o ingest ./cmd/ingest

FROM alpine:3.21
WORKDIR /app

RUN apk add --no-cache tzdata
ENV TZ=Asia/Tokyo

COPY --from=builder /app/ingest .
RUN addgroup -S app && adduser -S app -G app && chown app:app /app/ingest
USER app

ENTRYPOINT ["./ingest"]